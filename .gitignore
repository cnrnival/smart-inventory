# ==============================================================================
# SMART INVENTORY - GESTÃO DE VALIDADE (FEFO)
# ==============================================================================

# 📦 Dependências e Pacotes
# Não ignoramos o package-lock.json para garantir consistência no Vercel
node_modules/
**/node_modules/
yarn.lock
pnpm-lock.yaml

# 🏗️ Next.js (Frontend)
# Protege contra o erro da pasta .next fora do lugar
.next/
**/ .next/
out/
build/
dist/
.vercel

# 🐍 Python & Backend
# Protege o ambiente virtual e arquivos de cache
backend/venv/
venv/
ENV/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.Python

# 🗄️ Bancos de Dados e Dados Sensíveis
# Ignora o banco local para não sobrescrever dados de produção
*.db
*.sqlite
backend/inventory.db
# Se houver arquivos de dados que NÃO devem subir:
# backend/products.json
# backend/users.json

# 🔐 Variáveis de Ambiente
.env
.env.local
.env.production
.env.development
.env.*.local

# 💻 IDEs e Sistema Operacional
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# 📝 Logs e Debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

backend/.env